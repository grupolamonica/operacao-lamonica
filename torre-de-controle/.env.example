# Backend API URL
VITE_API_URL=http://localhost:3000

# Sentry (Phase 6) — opcional em dev
# Inicializado em src/lib/sentry.ts via initSentry() em main.tsx
VITE_SENTRY_DSN=

# Web Push (Phase 6) — public key (safe to expose)
# Pareada com VAPID_PRIVATE_KEY no backend; gerar com `bunx web-push generate-vapid-keys --json`
VITE_VAPID_PUBLIC_KEY=

# Build CI / source maps (NÃO commitar valores reais — Cloudflare Pages env store)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=torre-frontend
