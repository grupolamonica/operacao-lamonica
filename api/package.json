{
  "name": "torre-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed/index.ts",
    "db:reset": "bun run src/db/seed/reset.ts && bun run db:push && bun run db:seed",
    "sim": "bun run src/scripts/gps-simulator.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/jwt": "1.4.2",
    "@elysiajs/swagger": "1.3.1",
    "bcrypt": "6.0.0",
    "drizzle-orm": "0.45.2",
    "elysia": "1.4.28",
    "ioredis": "5.10.1",
    "pino": "10.3.1",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@faker-js/faker": "9.0.3",
    "@types/bcrypt": "6.0.0",
    "bun-types": "latest",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "latest",
    "typescript": "^6.0.3"
  }
}
