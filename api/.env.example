# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/torre_controle

# Redis
REDIS_URL=redis://localhost:6379

# Auth (HS256 — D-01 / RESEARCH.md Pitfall #1: HS256 chosen for MVP)
JWT_SECRET=replace-with-64-byte-hex-secret-in-production
JWT_EXPIRES_IN=24h

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug

# NOTE: Bun is not installed locally on this machine.
# All bun commands must be run via Docker:
#   docker compose exec api bun run db:seed
#   docker compose exec api bun run db:migrate
#   docker compose exec api bun run db:generate
# For local dev without Bun, use: docker compose up -d

# Telemetry
TELEMETRY_API_KEY=dev-telemetry-key

# Web Push (Phase 6) — gerar com: bunx web-push generate-vapid-keys --json
# Public key vai pro frontend (VITE_VAPID_PUBLIC_KEY); private fica só no backend.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@torredecontrole.com

# Sentry (Phase 6) — opcional em dev, obrigatório em prod
# beforeSend() em api/src/lib/sentry.ts scrub recursivo de PII (LGPD)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
