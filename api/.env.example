# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/torre_controle

# Redis
REDIS_URL=redis://localhost:6379

# Auth (HS256 — D-01 / RESEARCH.md Pitfall #1: HS256 chosen for MVP)
JWT_SECRET=replace-with-64-byte-hex-secret-in-production
JWT_EXPIRES_IN=24h

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug

# NOTE: Bun is not installed locally on this machine.
# All bun commands must be run via Docker:
#   docker compose exec api bun run db:seed
#   docker compose exec api bun run db:migrate
#   docker compose exec api bun run db:generate
# For local dev without Bun, use: docker compose up -d

# Telemetry
TELEMETRY_API_KEY=dev-telemetry-key

# Web Push (Phase 6) — gerar com: bunx web-push generate-vapid-keys --json
# Public key vai pro frontend (VITE_VAPID_PUBLIC_KEY); private fica só no backend.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@torredecontrole.com

# Sentry (Phase 6) — opcional em dev, obrigatório em prod
# beforeSend() em api/src/lib/sentry.ts scrub recursivo de PII (LGPD)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Ranking (Phase 7 — Supabase "Lamonica Ranking", projeto qbwazymqhfunlhnikbla, sa-east-1)
# D-V2-01 (PROXY): o Torre lê o ranking server-side; o front consome /api/ranking/* via cookie do Torre.
RANK_SUPABASE_URL=https://qbwazymqhfunlhnikbla.supabase.co
# Chave anon/publishable do projeto Lamonica Ranking. O RLS libera cmd=ALL para o public nas 5
# tabelas (confirmado via MCP: qual=true, with_check=true) — a anon key basta para LEITURA (Phase 7)
# e ESCRITA (Phase 9). SERVER-SIDE ONLY — nunca VITE_*/logs/bundle. (D-09-03)
# Phase 9: writes confirmed working with the anon key — RLS is open (D-09-03).
# (trocar por service_role se o RLS de escrita bloquear o anon em projetos futuros)
RANK_SUPABASE_SERVICE_KEY=
# Google Sheets CSV público (gviz) — sem credencial.
RANK_SHEET_ID=1MWTiaXU3HXW_iVn-n70WSk3o8rcHTRrQP2ac07W9cCU
RANK_SHEET_TAB=DBLHHISTORICO

# Cargas (Phase 14 — D-14) — integração híbrida com o sistema de Cargas (Lamonica)
# LEITURA: Supabase do Cargas (TEST = oklksqvrexiypectfsod). Use a service_role key. SERVER-SIDE ONLY.
CARGAS_SUPABASE_URL=https://<project-ref>.supabase.co
CARGAS_SUPABASE_KEY=
# ESCRITA (alocação): API HTTP de operador do Cargas. A Torre faz sign-in Supabase (password) → Bearer.
# Operador precisa de access_level >= intermediário (leads:write). NUNCA commitar valores reais.
CARGAS_API_URL=http://localhost:3001
CARGAS_OPERATOR_EMAIL=
CARGAS_OPERATOR_PASSWORD=
# Feature flag de escrita: false = só leitura (UI de alocação desabilitada). true = grava no Cargas.
CARGAS_WRITE_ENABLED=false
